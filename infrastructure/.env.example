# ==================================================================
# URL Shortener — infrastructure repo
# Copy to .env and adjust values. Do NOT commit .env.
# ==================================================================

# ---- Postgres ----------------------------------------------------
POSTGRES_DB=urlshortener
POSTGRES_USER=ushortener
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Dev-only: host-level port mapping (prod da olib tashlanadi)
POSTGRES_HOST_PORT=5432

# ---- Redis cache (port 6379) -------------------------------------
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379
REDIS_CACHE_HOST_PORT=6379

# ---- Redis app (port 6380, streams + rate limit) -----------------
REDIS_APP_HOST=redis-app
REDIS_APP_PORT=6380
REDIS_APP_HOST_PORT=6380

# ---- ClickHouse --------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
# SECURITY: leave empty only for local dev. If you flip
# CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT to "1" in docker-compose.yml to enable
# RBAC, you MUST set a strong password here — otherwise the default user gets
# superuser rights over the shared Docker network with no auth.
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST_PORT=9000

# ---- JWT ---------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_bytes
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ---- MinIO (S3) --------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_dev_only

# ---- GeoIP (MaxMind) --------------------------------------------
# https://www.maxmind.com/ ga ro'yxatdan o'ting, GeoLite2 kalitini oling.
# Agar bo'sh qoldirilsa, geoip-updater kontayneri ishga tushadi lekin muvaffaqiyatsiz bo'ladi.
GEOIP_ACCOUNT_ID=
GEOIP_LICENSE_KEY=
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ---- Grafana -----------------------------------------------------
# RV10 2.12: pick a NON-default admin password. The stack will refuse to
# start if GRAFANA_ADMIN_PASSWORD is unset or equal to "admin".
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_to_a_strong_password

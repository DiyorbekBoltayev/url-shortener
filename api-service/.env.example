# =============================================================
# api-service — .env example
# Copy to .env and fill secrets. Do not commit .env.
# =============================================================

# ---- Postgres -----------------------------------------------
# SQLAlchemy DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ushortener:changeme_dev_only@postgres:5432/urlshortener

# ---- Redis --------------------------------------------------
# Cache DB: URL -> long_url lookups (shared with redirect-service reader)
REDIS_CACHE_URL=redis://redis-cache:6379/0
# Application DB: rate limits, JWT denylist, API-key cache, stats
REDIS_APP_URL=redis://redis-app:6380/0

# ---- ClickHouse ---------------------------------------------
# HTTP endpoint used by clickhouse-connect async client
CLICKHOUSE_URL=clickhouse://default:@clickhouse:8123/analytics
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=analytics

# ---- JWT ----------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ---- CORS ---------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://admin-panel

# ---- Safe Browsing (optional) -------------------------------
# Leave empty to disable Google Safe Browsing lookups
SAFE_BROWSING_API_KEY=

# ---- Webhooks -----------------------------------------------
WEBHOOK_SIGNING_KEY=change_this_webhook_signing_key

# ---- Observability ------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# ---- Rate limits (defaults per plan, per minute) ------------
RL_DEFAULT_PER_MIN=120

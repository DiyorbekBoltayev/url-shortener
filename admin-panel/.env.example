# Build-time configuration for the admin-panel SPA.
# Angular Inlines environment.*.ts files at build time via fileReplacements.
# For runtime overrides without rebuild, mount a /assets/config.json into nginx.

# Base URL for API calls. In docker/prod this is "/api" (same-origin proxy via nginx).
# In standalone dev without proxy, point to the api-service directly.
API_BASE_URL=/api

# Public short-link host (used for copy-to-clipboard URL construction).
PUBLIC_SHORT_HOST=http://localhost

# App display name.
APP_NAME=URL Shortener Admin

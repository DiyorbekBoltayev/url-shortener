# ======== Redis (app stream, db=0, port 6380) ========
REDIS_STREAM_URL=redis://redis-app:6380/0

# ======== ClickHouse ========
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ======== Stream contract (LOCKED by INTEGRATION_CONTRACT.md) ========
STREAM_NAME=stream:clicks
CONSUMER_GROUP=analytics

# ======== Batching ========
BATCH_SIZE=1000
FLUSH_INTERVAL_SEC=1.0
READ_COUNT=100
READ_BLOCK_MS=5000

# ======== PEL reclaimer ========
PEL_IDLE_MS=300000
PEL_CLAIM_INTERVAL_SEC=60.0
PEL_MAX_DELIVERIES=16

# ======== GeoIP (shared volume from infrastructure) ========
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ======== Observability ========
METRICS_PORT=9091
HEALTH_PORT=9092
LOG_LEVEL=INFO

# redirect-service — environment configuration
# Copy to .env and adjust. Do NOT commit .env.

# HTTP
HTTP_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json

# Redis (two separate instances per INTEGRATION_CONTRACT section 4)
REDIS_CACHE_URL=redis://redis-cache:6379/0
REDIS_STREAM_URL=redis://redis-app:6380/0
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10
REDIS_READ_TIMEOUT_MS=200
REDIS_WRITE_TIMEOUT_MS=200

# Postgres
PG_DSN=postgres://ushortener:changeme_dev_only@postgres:5432/urlshortener?sslmode=disable
PG_MAX_CONNS=20
PG_MIN_CONNS=2
PG_QUERY_TIMEOUT_MS=200

# GeoIP
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# Streams
STREAM_NAME=stream:clicks
STREAM_MAXLEN=1000000
STREAM_WORKERS=4
STREAM_BUFFER=10000

# Cache TTLs
CACHE_TTL_HIT=24h
CACHE_TTL_MISS=5m

# Shutdown
SHUTDOWN_TIMEOUT=30s

# Proxy (trust X-Forwarded-For from nginx)
TRUST_PROXY=true
PROXY_HEADER=X-Forwarded-For

# Local dev only (overridden for docker — uses DNS names above):
# REDIS_CACHE_URL=redis://localhost:6379/0
# REDIS_STREAM_URL=redis://localhost:6380/0
# PG_DSN=postgres://ushortener:changeme_dev_only@localhost:5432/urlshortener?sslmode=disable
